# Copy to .env (git-ignored) or run scripts/gen_env.sh to generate one.
# Shared LAN API key — clients send it as the X-API-Key header.
API_KEY=replace-me-with-a-long-random-value

# Client OCR skill credentials are generated separately:
# scripts/gen_env.sh --client-credentials --gateway-host <SERVER_LAN_IP>:8080
# Copy client.credentials.env to ~/.config/glm-ocr/credentials.env on client machines.

# Internal vLLM endpoint (OpenAI-compatible). Leave as-is for the Compose stack.
VLLM_URL=http://vllm:8080/v1
MODEL=zai-org/GLM-OCR

# Limits.
MAX_PAGES=50
MAX_CONCURRENCY=1
QUEUE_MAX=8
SCRATCH_DIR=/scratch

# Corporate proxy passthrough (plain HTTP only on this host). Set to your proxy or blank out.
http_proxy=http://proxy.example.com:8080
# Internal + LAN traffic must NEVER hit the proxy. Add your LAN subnet.
NO_PROXY=localhost,127.0.0.1,vllm,192.168.0.0/16
